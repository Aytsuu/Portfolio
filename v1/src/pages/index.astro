---
import BaseLayout from "../layouts/BaseLayout.astro";
import { certificates } from "../dto/certificates.dto";
import { experiences } from "../dto/experiences.dto";
import { projects } from "../dto/projects.dto";
import { testimonials } from "../dto/recommendations";
import { socials } from "../dto/socials.dto";
import { techStacks } from "../dto/tech-stacks.dto";

import profilePicture from "../assets/my_profile_pic.png";
import resumePdf from "../assets/resume/main.pdf?url";
import meiroImage from "../assets/projects/meiro_project.png";
import portfolioImage from "../assets/projects/portfolio_project_dark.png";
import sanRoqueImage from "../assets/projects/sanroque_project.png";
import securadoImage from "../assets/projects/securado_project.png";
import bellImage from "../assets/testimonials/bell.jpg";
import narcisanImage from "../assets/testimonials/narcisan.jpg";
import suzetteImage from "../assets/testimonials/suzette.png";

const projectImageSources: Record<string, string> = {
  "/assets/projects/meiro_project.png": meiroImage.src,
  "/assets/projects/portfolio_project_dark.png": portfolioImage.src,
  "/assets/projects/sanroque_project.png": sanRoqueImage.src,
  "/assets/projects/securado_project.png": securadoImage.src,
};

const testimonialImageSources: Record<string, string> = {
  "/assets/testimonials/bell.jpg": bellImage.src,
  "/assets/testimonials/narcisan.jpg": narcisanImage.src,
  "/assets/testimonials/suzette.png": suzetteImage.src,
};

const certificateFiles = import.meta.glob<string>("../assets/certificates/*", {
  eager: true,
  import: "default",
  query: "?url",
});

const galleryImages = Object.entries(
  import.meta.glob<{ default: { src: string } }>("../assets/gallery/*.{jpg,jpeg,png,webp}", {
    eager: true,
  })
).map(([path, module]) => {
  const fileName = path.split("/").pop() ?? "Gallery image";

  return {
    src: module.default.src,
    alt: fileName.replace(/\.[^.]+$/, "").replace(/[-_]/g, " "),
  };
});

const contact = {
  name: "Paolo Araneta",
  role: "Software Engineer",
  location: "Cebu City, Philippines",
  email: "paoloaraneta008@gmail.com",
  phone: "(+63) 926-2355-926",
  summary:
    "Full-stack software engineer focused on practical web systems, automation workflows, and AI-assisted product development.",
};

const education = {
  school: "Cebu Technological University",
  program: "Bachelor of Science in Information Technology",
  location: "Cebu City, Philippines",
  period: "2022 - Expected July 2026",
};
---

<BaseLayout
  title={`${contact.name} Portfolio`}
  description="Semantic content structure for Paolo Araneta's personal portfolio."
>
  <header>
    <p>Personal portfolio</p>
    <h1>{contact.name}</h1>
    <p>{contact.role}</p>
    <p>{contact.location}</p>
    <p>{contact.summary}</p>

    <figure>
      <img src={profilePicture.src} alt={`${contact.name} profile portrait`} />
      <figcaption>{contact.name}</figcaption>
    </figure>

    <nav aria-label="Portfolio sections">
      <ul>
        <li><a href="#about">About</a></li>
        <li><a href="#experience">Experience</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#certificates">Certificates</a></li>
        <li><a href="#recommendations">Recommendations</a></li>
        <li><a href="#gallery">Gallery</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section id="about" aria-labelledby="about-heading">
      <h2 id="about-heading">About</h2>
      <p>
        Paolo Araneta is a software engineer and BS Information Technology student building web systems across frontend,
        backend, cloud, and AI-assisted workflows.
      </p>
      <p>
        This page is intentionally unstyled. It exists to define the portfolio's information architecture before visual
        design, interaction design, and animation work begin.
      </p>
      <p><a href={resumePdf}>View resume PDF</a></p>
    </section>

    <section id="contact-summary" aria-labelledby="contact-summary-heading">
      <h2 id="contact-summary-heading">Contact Summary</h2>
      <address>
        <p>{contact.name}</p>
        <p>{contact.location}</p>
        <p><a href={`mailto:${contact.email}`}>{contact.email}</a></p>
        <p><a href={`tel:${contact.phone.replaceAll(/[\s()-]/g, "")}`}>{contact.phone}</a></p>
      </address>
      <ul>
        {socials.map((social) => (
          <li><a href={social.link}>{social.type}</a></li>
        ))}
      </ul>
    </section>

    <section id="education" aria-labelledby="education-heading">
      <h2 id="education-heading">Education</h2>
      <article>
        <h3>{education.program}</h3>
        <p>{education.school}</p>
        <p>{education.location}</p>
        <p>{education.period}</p>
      </article>
    </section>

    <section id="experience" aria-labelledby="experience-heading">
      <h2 id="experience-heading">Experience</h2>
      <ol>
        {experiences.map((experience) => (
          <li>
            <article>
              <h3>{experience.title}</h3>
              <p>{experience.experiencedAt}</p>
              <p>{experience.year}</p>
              {experience.location && <p>{experience.location}</p>}
              {experience.highlights && (
                <ul>
                  {experience.highlights.map((highlight) => <li>{highlight}</li>)}
                </ul>
              )}
            </article>
          </li>
        ))}
      </ol>
    </section>

    <section id="projects" aria-labelledby="projects-heading">
      <h2 id="projects-heading">Projects</h2>
      <ol>
        {projects.map((project) => (
          <li>
            <article>
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              {projectImageSources[project.imageURI] && (
                <figure>
                  <img src={projectImageSources[project.imageURI]} alt={`${project.name} project screenshot`} />
                  <figcaption>{project.name} project visual reference</figcaption>
                </figure>
              )}
              <h4>Technology used</h4>
              <ul>
                {project.techStack.map((technology) => <li>{technology}</li>)}
              </ul>
              {project.link && <p><a href={project.link}>Visit project</a></p>}
            </article>
          </li>
        ))}
      </ol>
    </section>

    <section id="skills" aria-labelledby="skills-heading">
      <h2 id="skills-heading">Skills</h2>
      {techStacks.map((stack) => {
        const headingId = `skill-${stack.type.toLowerCase().replaceAll(/[^a-z0-9]+/g, "-")}`;

        return (
          <section aria-labelledby={headingId}>
            <h3 id={headingId}>{stack.type}</h3>
            <ul>
              {stack.items.map((item) => <li>{item}</li>)}
            </ul>
          </section>
        );
      })}
    </section>

    <section id="certificates" aria-labelledby="certificates-heading">
      <h2 id="certificates-heading">Certificates</h2>
      <ol>
        {certificates.map((certificate) => {
          const href = certificateFiles[`../assets/certificates/${certificate.fileName}`];

          return (
            <li>
              <article>
                <h3>{certificate.title}</h3>
                <p>{certificate.subtitle}</p>
                {href && <p><a href={href}>View certificate</a></p>}
              </article>
            </li>
          );
        })}
      </ol>
    </section>

    <section id="recommendations" aria-labelledby="recommendations-heading">
      <h2 id="recommendations-heading">Recommendations</h2>
      <ol>
        {testimonials.map((recommendation) => (
          <li>
            <figure>
              {testimonialImageSources[recommendation.imageURI] && (
                <img
                  src={testimonialImageSources[recommendation.imageURI]}
                  alt={`${recommendation.name} profile photo`}
                />
              )}
              <blockquote>
                <p>{recommendation.testimonial}</p>
              </blockquote>
              <figcaption>
                <p>{recommendation.name}</p>
                <p>{recommendation.company}</p>
              </figcaption>
            </figure>
          </li>
        ))}
      </ol>
    </section>

    <section id="gallery" aria-labelledby="gallery-heading">
      <h2 id="gallery-heading">Gallery</h2>
      <p>Uncurated image references available for future portfolio storytelling.</p>
      <ul>
        {galleryImages.map((image) => (
          <li>
            <figure>
              <img src={image.src} alt={image.alt} />
              <figcaption>{image.alt}</figcaption>
            </figure>
          </li>
        ))}
      </ul>
    </section>

    <section id="contact" aria-labelledby="contact-heading">
      <h2 id="contact-heading">Contact</h2>
      <p>Email: <a href={`mailto:${contact.email}`}>{contact.email}</a></p>
      <p>Phone: <a href={`tel:${contact.phone.replaceAll(/[\s()-]/g, "")}`}>{contact.phone}</a></p>
      <p>Resume: <a href={resumePdf}>Download resume</a></p>
    </section>
  </main>

  <footer>
    <p>{contact.name}</p>
    <nav aria-label="Social links">
      <ul>
        {socials.map((social) => (
          <li><a href={social.link}>{social.type}</a></li>
        ))}
      </ul>
    </nav>
  </footer>
</BaseLayout>
