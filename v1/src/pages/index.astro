---
import BaseLayout from "../layouts/BaseLayout.astro";
import { CertificateMarquee } from "../components/certificate-marquee";
import { GalleryGrid } from "../components/gallery-grid";
import { RecommendationCard } from "../components/recommendation-card";
import { SkillsGrid } from "../components/skills-grid";
import { DotPattern } from "../components/ui/dot-pattern";
import { certificates } from "../dto/certificates.dto";
import { experiences } from "../dto/experiences.dto";
import { projects } from "../dto/projects.dto";
import { testimonials } from "../dto/recommendations";
import { socials } from "../dto/socials.dto";

import { ResumeViewer } from "../components/resume-viewer";
import profilePicture from "../assets/my_profile_pic.png";
import meiroImage from "../assets/projects/meiro_project.png";
import portfolioImage from "../assets/projects/portfolio_project_dark.png";
import sanRoqueImage from "../assets/projects/sanroque_project.png";
import securadoImage from "../assets/projects/securado_project.png";
import bellImage from "../assets/testimonials/bell.jpg";
import narcisanImage from "../assets/testimonials/narcisan.jpg";
import suzetteImage from "../assets/testimonials/suzette.png";
import facebookIcon from "../assets/icons/facebook-dark.svg";
import githubIcon from "../assets/icons/github-dark.svg";
import instagramIcon from "../assets/icons/instagram-dark.svg";
import linkedinIcon from "../assets/icons/linkedin-dark.svg";

const projectImageSources: Record<string, string> = {
  "/assets/projects/meiro_project.png": meiroImage.src,
  "/assets/projects/portfolio_project_dark.png": portfolioImage.src,
  "/assets/projects/sanroque_project.png": sanRoqueImage.src,
  "/assets/projects/securado_project.png": securadoImage.src,
};

const testimonialImageSources: Record<string, string> = {
  "/assets/testimonials/bell.jpg": bellImage.src,
  "/assets/testimonials/narcisan.jpg": narcisanImage.src,
  "/assets/testimonials/suzette.png": suzetteImage.src,
};

const socialIconSources: Record<string, string> = {
  Facebook: facebookIcon.src,
  Github: githubIcon.src,
  Instagram: instagramIcon.src,
  LinkedIn: linkedinIcon.src,
};

const certificateFiles = import.meta.glob<string>("../assets/certificates/*", {
  eager: true,
  import: "default",
  query: "?url",
});

const certificatePreviewImages = import.meta.glob<string>(
  "../assets/certificates/*.{png,jpg,jpeg,webp}",
  {
    eager: true,
    import: "default",
    query: "?url",
  },
);

const certificatePreviewSources: Record<string, string | undefined> = {
  "2024 NASA International Space Apps Challenge":
    certificatePreviewImages[
      "../assets/certificates/2024 NASA Space Apps Challenge.png"
    ],
  "2025 NASA International Space Apps Challenge":
    certificatePreviewImages[
      "../assets/certificates/2025 NASA Space Apps Challenge.png"
    ],
  "DevFest Cebu 2025":
    certificatePreviewImages["../assets/certificates/Devfest Cebu 2025.png"],
  "AI Ready ASEAN":
    certificatePreviewImages["../assets/certificates/AI READY ASEAN.png"],
  "ASEAN AI Hackathon 2026::Passage to ASEAN (P2A) Secretariat":
    certificatePreviewImages[
      "../assets/certificates/ASEAN AI Hackathon 2026.png"
    ],
  "ASEAN AI Hackathon 2026::Mapua Malayan Colleges Laguna":
    certificatePreviewImages[
      "../assets/certificates/ASEAN AI - Mapua Malayan Colleges Laguna.png"
    ],
  "AWS AI Practitioner Challenge":
    certificatePreviewImages[
      "../assets/certificates/AWS AI Practitioner Challenge.png"
    ],
  "Build with AI Cebu 2026":
    certificatePreviewImages[
      "../assets/certificates/Build with AI Cebu 2026.png"
    ],
  "Data Analytics Fundamentals":
    certificatePreviewImages[
      "../assets/certificates/Data Analytics Fundamentals.png"
    ],
  "Google AI Professional":
    certificatePreviewImages[
      "../assets/certificates/Google AI Professional.png"
    ],
  "IBM Dev Day Bob Edition":
    certificatePreviewImages[
      "../assets/certificates/IBM Dev Day Bob Edition.png"
    ],
  "Reply AI Agent Challenge":
    certificatePreviewImages[
      "../assets/certificates/Reply AI Agent Challenge.png"
    ],
};

const marqueeCertificates = certificates
  .map((certificate) => {
    const href =
      certificateFiles[`../assets/certificates/${certificate.fileName}`];
    const imageSrc =
      certificatePreviewSources[
        `${certificate.title}::${certificate.issuer}`
      ] ?? certificatePreviewSources[certificate.title];

    return {
      title: certificate.title,
      issuer: certificate.issuer,
      href,
      imageSrc,
    };
  })
  .filter(
    (
      certificate,
    ): certificate is {
      title: string;
      issuer: string;
      href: string;
      imageSrc: string;
    } => Boolean(certificate.imageSrc),
  );

const galleryImages = Object.entries(
  import.meta.glob<{ default: { src: string } }>(
    "../assets/gallery/*.{jpg,jpeg,png,webp}",
    {
      eager: true,
    },
  ),
).map(([path, module]) => {
  const fileName = path.split("/").pop() ?? "Gallery image";

  return {
    src: module.default.src,
    alt: fileName.replace(/\.[^.]+$/, "").replace(/[-_]/g, " "),
  };
});
const contact = {
  name: "Paolo Araneta",
  role: "Software Engineer",
  location: "Cebu City, Philippines",
  email: "paoloaraneta008@gmail.com",
  phone: "(+63) 926-2355-926",
  summary:
    "Full-stack software engineer focused on practical web systems, automation workflows, and AI-assisted product development.",
};

const resumePdf = "/assets/resume/main.pdf";
---

<BaseLayout
  title={`${contact.name}`}
  description="Personal portfolio of Paolo Araneta, presenting engineering projects, experiences, and technical skills with a premium minimalist aesthetic."
>
  <div class="portfolio-layout">
    <aside class="portfolio-sidebar" aria-label="Portfolio sidebar">
      <nav aria-label="Portfolio sections">
        <ul>
          <li>
            <a href="#about"
              ><span data-text="Paolo Araneta">Paolo Araneta</span></a
            >
          </li>
          <li>
            <a href="#experience"
              ><span data-text="Experience">Experience</span></a
            >
          </li>
          <li>
            <a href="#projects"><span data-text="Projects">Projects</span></a>
          </li>
          <li><a href="#skills"><span data-text="Skills">Skills</span></a></li>
          <li>
            <a href="#certificates"
              ><span data-text="Certificates">Certificates</span></a
            >
          </li>
          <li>
            <a href="#recommendations"
              ><span data-text="Recommendations">Recommendations</span></a
            >
          </li>
          <li>
            <a href="#gallery"><span data-text="Gallery">Gallery</span></a>
          </li>
        </ul>
      </nav>
    </aside>

    <div class="portfolio-content">
      <main class="portfolio-main">
        <section
          id="about"
          class="section-block"
          aria-labelledby="portfolio-heading"
        >
          <div class="about-identity">
            <figure class="about-profile">
              <img
                src={profilePicture.src}
                alt={`${contact.name} profile portrait`}
              />
            </figure>
            <div class="about-heading">
              <h1 id="portfolio-heading">{contact.name}</h1>
              <p>{contact.role}</p>
              <p>{contact.location}</p>
              <p>{contact.summary}</p>
            </div>
          </div>

          <address class="contact-details">
            <div>
              Email: <a href={`mailto:${contact.email}`}>{contact.email}</a>
            </div>
            <div>
              Phone: <a href={`tel:${contact.phone.replaceAll(/[\s()-]/g, "")}`}
                >{contact.phone}</a
              >
            </div>
          </address>

          <ul class="social-list">
            {
              socials.map((social) => (
                <li>
                  <a
                    href={social.link}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {socialIconSources[social.type] && (
                      <img
                        src={socialIconSources[social.type]}
                        alt=""
                        aria-hidden="true"
                      />
                    )}
                    <span>{social.type}</span>
                  </a>
                </li>
              ))
            }
          </ul>

          <div class="resume-link">
            <button id="open-resume-btn" class="resume-btn cursor-pointer">Open Resume</button>
          </div>
        </section>

        <section
          id="experience"
          class="section-block"
          aria-labelledby="experience-heading"
        >
          <h2 id="experience-heading">Experience</h2>
          <ol class="experience-timeline">
            {
              experiences.map((experience) => (
                <li class="experience-timeline-item">
                  <article>
                    <h3>{experience.title}</h3>
                    <div class="experience-meta">
                      <span>{experience.experiencedAt}</span>
                      <span>{experience.year}</span>
                      {experience.location && (
                        <span>{experience.location}</span>
                      )}
                    </div>
                    {experience.highlights && (
                      <ul class="experience-highlights">
                        {experience.highlights.map((highlight) => (
                          <li>{highlight}</li>
                        ))}
                      </ul>
                    )}
                  </article>
                </li>
              ))
            }
          </ol>
        </section>

        <section
          id="projects"
          class="section-block"
          aria-labelledby="projects-heading"
        >
          <h2 id="projects-heading">Projects</h2>
          <div class="projects-placeholder">
            <DotPattern
              client:load
              width={16}
              height={16}
              cr={1}
              className="opacity-40 [mask-image:radial-gradient(300px_circle_at_center,white,transparent)]"
            />
            <div class="placeholder-icon relative z-10">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="size-6 animate-pulse"
              >
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
              </svg>
            </div>
            <p class="placeholder-text relative z-10">Building in progress</p>
          </div>
        </section>

        <section
          id="skills"
          class="section-block"
          aria-labelledby="skills-heading"
        >
          <h2 id="skills-heading">Skills</h2>
          <SkillsGrid client:load />
        </section>

        <section
          id="certificates"
          class="section-block"
          aria-labelledby="certificates-heading"
        >
          <h2 id="certificates-heading">Certificates</h2>
          <CertificateMarquee
            client:visible
            certificates={marqueeCertificates}
          />
        </section>

        <section
          id="recommendations"
          class="section-block"
          aria-labelledby="recommendations-heading"
        >
          <h2 id="recommendations-heading">Recommendations</h2>
          <div class="recommendations-list">
            {
              testimonials.map((recommendation) => (
                <RecommendationCard
                  client:load
                  testimonial={recommendation.testimonial}
                  name={recommendation.name}
                  company={recommendation.company}
                  imageSrc={testimonialImageSources[recommendation.imageURI]}
                />
              ))
            }
          </div>
        </section>

        <section
          id="gallery"
          class="section-block"
          aria-labelledby="gallery-heading"
        >
          <h2 id="gallery-heading">Gallery</h2>
          <GalleryGrid client:load images={galleryImages} />
        </section>
      </main>
    </div>
  </div>

  <dialog id="resume-modal" class="resume-dialog">
    <div class="dialog-floating-actions">
      <a href={resumePdf} download="Paolo_Araneta_Resume.pdf" class="floating-btn download" aria-label="Download resume">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      </a>
      <button id="close-resume-btn" class="floating-btn close" aria-label="Close modal">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="dialog-body">
      <ResumeViewer client:load src={resumePdf} title="Paolo Araneta Resume" />
    </div>
  </dialog>

  <script>
    // Scroll tracking for active navigation menu items
    const setupScrollSpy = () => {
      const sections = document.querySelectorAll("section.section-block");
      const navLinks = document.querySelectorAll(".portfolio-sidebar a");

      const activeObserverOptions = {
        root: null,
        rootMargin: "-20% 0px -50% 0px",
        threshold: 0,
      };

      const sectionVisibility = new Map();

      const activeObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          sectionVisibility.set(entry.target.id, entry.isIntersecting);
        });

        // Find the first visible section from top to bottom
        let activeId = null;
        for (const section of sections) {
          if (sectionVisibility.get(section.id)) {
            activeId = section.id;
            break;
          }
        }

        // Fallback to top-most section if scrolled to top
        if (window.scrollY < 100) {
          activeId = "about";
        }

        if (activeId) {
          navLinks.forEach((link) => {
            const href = link.getAttribute("href");
            link.classList.toggle("active", href === `#${activeId}`);
          });
        }
      }, activeObserverOptions);

      sections.forEach((section) => {
        activeObserver.observe(section);
      });

      // Simple click handler to immediately set active state and avoid lag during smooth scroll
      navLinks.forEach((link) => {
        link.addEventListener("click", () => {
          const href = link.getAttribute("href");
          if (href) {
            navLinks.forEach((l) => l.classList.toggle("active", l === link));
          }
        });
      });

      // Keep scrolling back to top correctly highlighted as "about"
      window.addEventListener("scroll", () => {
        if (window.scrollY < 50) {
          navLinks.forEach((link) => {
            const href = link.getAttribute("href");
            link.classList.toggle("active", href === "#about");
          });
        }
      });
    };

    const setupResumeModal = () => {
      const openBtn = document.getElementById("open-resume-btn");
      const closeBtn = document.getElementById("close-resume-btn");
      const modal = document.getElementById("resume-modal");

      if (openBtn && closeBtn && modal instanceof HTMLDialogElement) {
        openBtn.addEventListener("click", () => {
          modal.showModal();
          document.body.style.overflow = "hidden";
        });

        const closeModal = () => {
          modal.close();
          document.body.style.overflow = "";
        };

        closeBtn.addEventListener("click", closeModal);

        modal.addEventListener("click", (e) => {
          if (e.target === modal) {
            closeModal();
          }
        });

        modal.addEventListener("close", () => {
          document.body.style.overflow = "";
        });
      }
    };

    document.addEventListener("DOMContentLoaded", () => {
      setupScrollSpy();
      setupResumeModal();
    });
  </script>
</BaseLayout>
