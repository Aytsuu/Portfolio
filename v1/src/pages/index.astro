---
import FeatureTile from "../components/FeatureTile.astro";
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const featureTiles = [
  {
    label: "Static first",
    body: "Ship HTML by default and add client JavaScript only where the feature requires interactivity.",
    meta: "01",
  },
  {
    label: "Thin routes",
    body: "Keep route files small and move reusable data shaping and domain logic into focused modules.",
    meta: "02",
  },
  {
    label: "Selective islands",
    body: "Hydrate only the smallest widget that needs the browser instead of broad page sections.",
    meta: "03",
  },
];
---

<BaseLayout
  title="Astro Boilerplate"
  description="Minimal Astro boilerplate for project-context-factory."
>
  <main class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8 lg:py-20">
    <Hero
      title="Start with static-first Astro"
      body="Use this starter as the baseline. Add routes, content collections, integrations, and islands only when the feature requires them."
    />

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      {featureTiles.map((feature) => <FeatureTile {...feature} />)}
    </section>
  </main>
</BaseLayout>
