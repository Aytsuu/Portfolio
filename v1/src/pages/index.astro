---
import BaseLayout from "../layouts/BaseLayout.astro";
import { certificates } from "../dto/certificates.dto";
import { experiences } from "../dto/experiences.dto";
import { projects } from "../dto/projects.dto";
import { testimonials } from "../dto/recommendations";
import { socials } from "../dto/socials.dto";
import { techStacks } from "../dto/tech-stacks.dto";

import profilePicture from "../assets/my_profile_pic.png";
import resumePdf from "../assets/resume/main.pdf?url";
import meiroImage from "../assets/projects/meiro_project.png";
import portfolioImage from "../assets/projects/portfolio_project_dark.png";
import sanRoqueImage from "../assets/projects/sanroque_project.png";
import securadoImage from "../assets/projects/securado_project.png";
import bellImage from "../assets/testimonials/bell.jpg";
import narcisanImage from "../assets/testimonials/narcisan.jpg";
import suzetteImage from "../assets/testimonials/suzette.png";
import facebookIcon from "../assets/icons/facebook-dark.svg";
import githubIcon from "../assets/icons/github-dark.svg";
import instagramIcon from "../assets/icons/instagram-dark.svg";
import linkedinIcon from "../assets/icons/linkedin-dark.svg";

const projectImageSources: Record<string, string> = {
  "/assets/projects/meiro_project.png": meiroImage.src,
  "/assets/projects/portfolio_project_dark.png": portfolioImage.src,
  "/assets/projects/sanroque_project.png": sanRoqueImage.src,
  "/assets/projects/securado_project.png": securadoImage.src,
};

const testimonialImageSources: Record<string, string> = {
  "/assets/testimonials/bell.jpg": bellImage.src,
  "/assets/testimonials/narcisan.jpg": narcisanImage.src,
  "/assets/testimonials/suzette.png": suzetteImage.src,
};

const socialIconSources: Record<string, string> = {
  Facebook: facebookIcon.src,
  Github: githubIcon.src,
  Instagram: instagramIcon.src,
  LinkedIn: linkedinIcon.src,
};

const certificateFiles = import.meta.glob<string>("../assets/certificates/*", {
  eager: true,
  import: "default",
  query: "?url",
});

const galleryImages = Object.entries(
  import.meta.glob<{ default: { src: string } }>(
    "../assets/gallery/*.{jpg,jpeg,png,webp}",
    {
      eager: true,
    },
  ),
).map(([path, module]) => {
  const fileName = path.split("/").pop() ?? "Gallery image";

  return {
    src: module.default.src,
    alt: fileName.replace(/\.[^.]+$/, "").replace(/[-_]/g, " "),
  };
});

const contact = {
  name: "Paolo Araneta",
  role: "Software Engineer",
  location: "Cebu City, Philippines",
  email: "paoloaraneta008@gmail.com",
  phone: "(+63) 926-2355-926",
  summary:
    "Full-stack software engineer focused on practical web systems, automation workflows, and AI-assisted product development.",
};
---

<BaseLayout
  title={`${contact.name}`}
  description="Personal portfolio of Paolo Araneta, presenting engineering projects, experiences, and technical skills with a premium minimalist aesthetic."
>
  <div class="portfolio-layout">
    <aside class="portfolio-sidebar" aria-label="Portfolio sidebar">
      <nav aria-label="Portfolio sections">
        <ul>
          <li><a href="#about"><span data-text="Paolo Araneta">Paolo Araneta</span></a></li>
          <li><a href="#experience"><span data-text="Experience">Experience</span></a></li>
          <li><a href="#projects"><span data-text="Projects">Projects</span></a></li>
          <li><a href="#skills"><span data-text="Skills">Skills</span></a></li>
          <li><a href="#certificates"><span data-text="Certificates">Certificates</span></a></li>
          <li><a href="#recommendations"><span data-text="Recommendations">Recommendations</span></a></li>
          <li><a href="#gallery"><span data-text="Gallery">Gallery</span></a></li>
        </ul>
      </nav>
    </aside>

    <div class="portfolio-content">
      <main class="portfolio-main">
        <section
          id="about"
          class="section-block fade-in-section"
          aria-labelledby="portfolio-heading"
        >
          <div class="about-identity">
            <figure class="about-profile">
              <img
                src={profilePicture.src}
                alt={`${contact.name} profile portrait`}
              />
            </figure>
            <div class="about-heading">
              <h1 id="portfolio-heading">{contact.name}</h1>
              <p>{contact.role}</p>
              <p>{contact.location}</p>
              <p>{contact.summary}</p>
            </div>
          </div>

          <address class="contact-details">
            <div>
              Email: <a href={`mailto:${contact.email}`}>{contact.email}</a>
            </div>
            <div>
              Phone: <a href={`tel:${contact.phone.replaceAll(/[\s()-]/g, "")}`}
                >{contact.phone}</a
              >
            </div>
          </address>

          <ul class="social-list">
            {
              socials.map((social) => (
                <li>
                  <a
                    href={social.link}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {socialIconSources[social.type] && (
                      <img
                        src={socialIconSources[social.type]}
                        alt=""
                        aria-hidden="true"
                      />
                    )}
                    <span>{social.type}</span>
                  </a>
                </li>
              ))
            }
          </ul>

          <div class="resume-link">
            <a href={resumePdf} class="resume-btn" target="_blank"
              >Download Resume PDF</a
            >
          </div>
        </section>

        <section
          id="experience"
          class="section-block fade-in-section"
          aria-labelledby="experience-heading"
        >
          <h2 id="experience-heading">Experience</h2>
          <ol class="experience-timeline">
            {
              experiences.map((experience) => (
                <li class="experience-timeline-item">
                  <article>
                    <h3>{experience.title}</h3>
                    <div class="experience-meta">
                      <span>{experience.experiencedAt}</span>
                      <span>{experience.year}</span>
                      {experience.location && (
                        <span>{experience.location}</span>
                      )}
                    </div>
                    {experience.highlights && (
                      <ul class="experience-highlights">
                        {experience.highlights.map((highlight) => (
                          <li>{highlight}</li>
                        ))}
                      </ul>
                    )}
                  </article>
                </li>
              ))
            }
          </ol>
        </section>

        <section
          id="projects"
          class="section-block fade-in-section"
          aria-labelledby="projects-heading"
        >
          <h2 id="projects-heading">Projects</h2>
          <div class="projects-grid">
            {
              projects.map((project) => (
                <article class="project-card">
                  {projectImageSources[project.imageURI] && (
                    <div class="project-media">
                      <img
                        src={projectImageSources[project.imageURI]}
                        alt={`${project.name} project screenshot`}
                      />
                    </div>
                  )}
                  <div class="project-info">
                    <h3>{project.name}</h3>
                    <p>{project.description}</p>
                    {project.link && (
                      <a
                        href={project.link}
                        class="project-link-anchor"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        Visit project →
                      </a>
                    )}
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section
          id="skills"
          class="section-block fade-in-section"
          aria-labelledby="skills-heading"
        >
          <h2 id="skills-heading">Skills</h2>
          <div class="skills-container">
            {
              techStacks.map((stack) => {
                const headingId = `skill-${stack.type.toLowerCase().replaceAll(/[^a-z0-9]+/g, "-")}`;

                return (
                  <section class="skill-category" aria-labelledby={headingId}>
                    <h3 id={headingId}>{stack.type}</h3>
                    <ul class="skill-tags">
                      {stack.items.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </section>
                );
              })
            }
          </div>
        </section>

        <section
          id="certificates"
          class="section-block fade-in-section"
          aria-labelledby="certificates-heading"
        >
          <h2 id="certificates-heading">Certificates</h2>
          <div class="certificates-grid">
            {
              certificates.map((certificate) => {
                const href =
                  certificateFiles[
                    `../assets/certificates/${certificate.fileName}`
                  ];

                return (
                  <article class="certificate-card">
                    <div>
                      <h3>{certificate.title}</h3>
                      <p class="certificate-subtitle">{certificate.subtitle}</p>
                    </div>
                    {href && (
                      <a
                        href={href}
                        class="certificate-link"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        View certificate →
                      </a>
                    )}
                  </article>
                );
              })
            }
          </div>
        </section>

        <section
          id="recommendations"
          class="section-block fade-in-section"
          aria-labelledby="recommendations-heading"
        >
          <h2 id="recommendations-heading">Recommendations</h2>
          <div class="recommendations-list">
            {
              testimonials.map((recommendation) => (
                <article class="recommendation-card">
                  <blockquote class="recommendation-quote">
                    <p>{recommendation.testimonial}</p>
                  </blockquote>
                  <div class="recommendation-author">
                    {testimonialImageSources[recommendation.imageURI] && (
                      <div class="recommendation-avatar">
                        <img
                          src={testimonialImageSources[recommendation.imageURI]}
                          alt={`${recommendation.name} profile photo`}
                        />
                      </div>
                    )}
                    <div class="recommendation-details">
                      <span class="recommendation-name">
                        {recommendation.name}
                      </span>
                      <span class="recommendation-title">
                        {recommendation.company}
                      </span>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section
          id="gallery"
          class="section-block fade-in-section"
          aria-labelledby="gallery-heading"
        >
          <h2 id="gallery-heading">Gallery</h2>
          <p>
            Uncurated image references of work environments, blueprints, and
            code setups.
          </p>
          <ul class="gallery-grid">
            {
              galleryImages.map((image) => (
                <li class="gallery-card">
                  <img src={image.src} alt={image.alt} />
                </li>
              ))
            }
          </ul>
        </section>
      </main>
    </div>
  </div>

  <script>
    // Intersection Observer for scroll animations
    const observerOptions = {
      root: null,
      rootMargin: "0px 0px -10% 0px",
      threshold: 0.05,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Scroll tracking for active navigation menu items
    const setupScrollSpy = () => {
      const sections = document.querySelectorAll("section.section-block");
      const navLinks = document.querySelectorAll(".portfolio-sidebar a");
      
      const activeObserverOptions = {
        root: null,
        rootMargin: "-20% 0px -50% 0px",
        threshold: 0,
      };

      const sectionVisibility = new Map();

      const activeObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          sectionVisibility.set(entry.target.id, entry.isIntersecting);
        });

        // Find the first visible section from top to bottom
        let activeId = null;
        for (const section of sections) {
          if (sectionVisibility.get(section.id)) {
            activeId = section.id;
            break;
          }
        }

        // Fallback to top-most section if scrolled to top
        if (window.scrollY < 100) {
          activeId = "about";
        }

        if (activeId) {
          navLinks.forEach((link) => {
            const href = link.getAttribute("href");
            link.classList.toggle("active", href === `#${activeId}`);
          });
        }
      }, activeObserverOptions);

      sections.forEach((section) => {
        activeObserver.observe(section);
      });

      // Simple click handler to immediately set active state and avoid lag during smooth scroll
      navLinks.forEach((link) => {
        link.addEventListener("click", () => {
          const href = link.getAttribute("href");
          if (href) {
            navLinks.forEach((l) => l.classList.toggle("active", l === link));
          }
        });
      });

      // Keep scrolling back to top correctly highlighted as "about"
      window.addEventListener("scroll", () => {
        if (window.scrollY < 50) {
          navLinks.forEach((link) => {
            const href = link.getAttribute("href");
            link.classList.toggle("active", href === "#about");
          });
        }
      });
    };

    document.addEventListener("DOMContentLoaded", () => {
      const sections = document.querySelectorAll(".fade-in-section");
      sections.forEach((section) => {
        observer.observe(section);
      });

      setupScrollSpy();
    });
  </script>
</BaseLayout>
