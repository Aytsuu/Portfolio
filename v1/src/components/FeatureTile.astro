---
interface Props {
  label: string;
  body: string;
  meta?: string;
}

const { label, body, meta } = Astro.props;
---

<article class="flex min-h-40 flex-col justify-between gap-6 rounded-panel border border-rule bg-surface p-5 shadow-panel">
  <div>
    <p class="text-xs font-semibold uppercase text-accent">{label}</p>
    <p class="mt-3 text-sm leading-6 text-muted">{body}</p>
  </div>
  {meta && <p class="text-xs font-medium text-ink/45" aria-hidden="true">{meta}</p>}
</article>
